# Supabase — copy this file to .env.local and fill in your project values.
# Get these from: Supabase Dashboard → your project → Settings → API Keys
#
# Use the publishable key (format: sb_publishable_xxx) from the "API Keys" tab.
# This is the safe-to-expose client key — it respects Row Level Security (RLS).
# (The legacy "anon" key from the "Legacy API Keys" tab also works during the transition.)

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
